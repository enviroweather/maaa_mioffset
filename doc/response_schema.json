{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        }
      },
      "required": [
        "version",
        "timestamp"
      ]
    },
    "inputs": {
      "type": "object",
      "properties": {
        "lat": {
          "type": "number"
        },
        "lon": {
          "type": "number"
        },
        "oef": {
          "type": "integer"
        }
      },
      "required": [
        "lat",
        "lon",
        "oef"
      ]
    },
    "outputs": {
      "type": "object",
      "properties": {
        "raw": {
          "type": "object",
          "properties": {
            "format": {
              "type": "string"
            },
            "data": {
              "type": "object",
              "properties": {
                "5percent": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  }
                },
                "3percent": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  }
                },
                "1.5percent": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  }
                }
              },
              "required": [
                "5percent",
                "3percent",
                "1.5percent"
              ]
            }
          },
          "required": [
            "format",
            "data"
          ]
        },
        "table": {
          "type": "object",
          "properties": {
            "format": {
              "type": "string"
            },
            "data": {
              "type": "string"
            }
          },
          "required": [
            "format",
            "data"
          ]
        },
        "map": {
          "type": "object",
          "properties": {
            "format": {
              "type": "string"
            },
            "data": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string"
                },
                "features": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string"
                      },
                      "geometry": {
                        "type": "object",
                        "properties": {
                          "type": {
                            "type": "string"
                          },
                          "coordinates": {
                            "type": "array",
                            "items": {
                              "type": "number"
                            }
                          }
                        },
                        "required": [
                          "type",
                          "coordinates"
                        ]
                      },
                      "properties": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "odor_emission_factor": {
                            "type": "integer"
                          }
                        },
                        "required": [
                          "name",
                          "odor_emission_factor"
                        ]
                      }
                    },
                    "required": [
                      "type",
                      "geometry",
                      "properties"
                    ]
                  }
                }
              },
              "required": [
                "type",
                "features"
              ]
            }
          },
          "required": [
            "format",
            "data"
          ]
        },
        "plot": {
          "type": "object",
          "properties": {
            "format": {
              "type": "string"
            },
            "data": {
              "type": "string"
            }
          },
          "required": [
            "format",
            "data"
          ]
        }
      },
      "required": [
        "raw",
        "table",
        "map",
        "plot"
      ]
    }
  },
  "required": [
    "meta",
    "inputs",
    "outputs"
  ]
}